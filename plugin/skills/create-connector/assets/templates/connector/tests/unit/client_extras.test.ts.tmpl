  //     expect(calledUrl).toContain("/v1/customers/cus_1");
  //     expect(calledHeaders["Authorization"]).toMatch(/^Bearer /);
  //   });
  // )

  it("classifies HTTP 401 as UNAUTHORIZED, non-retriable", async () => {
    const client = makeClient({}, async () =>
      jsonResponse({ error: "unauthorized" }, { status: 401 }),
    );
    const r = await client.request("GET", "/healthz");
    expect(r.ok).toBe(false);
    if (!r.ok) {
      expect(r.code).toBe("UNAUTHORIZED");
      expect(r.retriable).toBe(false);
    }
  });

  it("retries on HTTP 500 then succeeds", async () => {
    let calls = 0;
    const client = makeClient({}, async () => {
      calls += 1;
      if (calls < 2) return jsonResponse({}, { status: 500 });
      return jsonResponse({ ok: true });
    });
    const r = await client.request("GET", "/healthz");
    expect(r.ok).toBe(true);
    expect(calls).toBe(2);
  });
});
