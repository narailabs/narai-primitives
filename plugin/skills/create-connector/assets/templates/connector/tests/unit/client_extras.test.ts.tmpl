/**
 * Per-method tests for {{ServicePascal}}Client. Mock the fetch implementation,
 * assert that the client emits the right URL/method/body and parses the
 * response correctly into the Result envelope.
 */
import { describe, expect, it } from "vitest";
import {
  {{ServicePascal}}Client,
  type {{ServicePascal}}ClientOptions,
} from "../../src/lib/{{SERVICE_SLUG}}_client.js";

function jsonResponse(
  body: unknown,
  init: { status?: number; headers?: Record<string, string> } = {},
): Response {
  return new Response(JSON.stringify(body), {
    status: init.status ?? 200,
    headers: {
      "Content-Type": "application/json",
      ...(init.headers ?? {}),
    },
  });
}

function makeClient(
  overrides: Partial<{{ServicePascal}}ClientOptions>,
  fetchMock: (url: string, init?: RequestInit) => Promise<Response>,
): {{ServicePascal}}Client {
  return new {{ServicePascal}}Client({
{{TEST_CLIENT_CREDS}}
    rateLimitPerMin: 100,
    connectTimeoutMs: 50,
    readTimeoutMs: 50,
    fetchImpl: async (url, init) => fetchMock(String(url), init),
    sleepImpl: async () => {},
    ...overrides,
  });
}

