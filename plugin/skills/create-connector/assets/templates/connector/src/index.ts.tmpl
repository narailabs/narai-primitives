import {
  createConnector,
  type Connector,
  type ErrorCode,
} from "@narai/connector-toolkit";
import { z } from "zod";
import {
  {{ServicePascal}}Client,
  load{{ServicePascal}}Credentials,
  type {{ServicePascal}}Result,
} from "./lib/{{SERVICE_SLUG}}_client.js";
