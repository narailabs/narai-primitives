{
  "name": "@narai/credential-providers",
  "version": "0.2.1",
  "description": "Pluggable secret-resolution for Node: env vars, JSON files, macOS/Linux keychain, Windows Credential Manager, and AWS / GCP / Azure cloud secret managers. Zero runtime dependencies; cloud + Windows SDKs loaded on demand.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "node bench/run.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "tinybench": "^4.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narailabs/credential-providers.git"
  },
  "bugs": {
    "url": "https://github.com/narailabs/credential-providers/issues"
  },
  "homepage": "https://github.com/narailabs/credential-providers#readme",
  "keywords": [
    "credentials",
    "secrets",
    "keychain",
    "env",
    "aws-secrets-manager",
    "gcp-secret-manager",
    "azure-key-vault"
  ]
}
